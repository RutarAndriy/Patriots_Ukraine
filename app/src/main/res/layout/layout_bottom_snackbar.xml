<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="@dimen/size_tool_bar"
    app:behavior_hideable="true"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
    android:background="?attr/colorPrimary"
    android:id="@+id/bottom_sheet_snackbar">

    <TextView
        android:id="@+id/snackbar_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="left|center_vertical"
        android:layout_marginLeft="@dimen/value_xxlarge"
        android:text="Test Snackbar"
        android:textColor="?attr/color_text_light"
        android:textSize="@dimen/size_text_normal" />

    <TextView
        android:id="@+id/bottom_pane_01"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom|center"
        android:background="?attr/color_background"
        android:visibility="gone" />

</FrameLayout>