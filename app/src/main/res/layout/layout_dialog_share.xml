<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <com.rutar.patriots_ukraine.custom_views.Web_Share_View
        android:id="@+id/share_web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarThumbHorizontal="?attr/scrollbar"
        android:scrollbarThumbVertical="?attr/scrollbar">

    </com.rutar.patriots_ukraine.custom_views.Web_Share_View>

    <ImageView
        android:id="@+id/share_loading"
        android:layout_width="@dimen/image_share"
        android:layout_height="@dimen/image_share"
        android:layout_gravity="center"
        android:layout_margin="@dimen/size_tool_bar_half"
        android:src="?attr/share_loading"
        android:visibility="invisible" />

</FrameLayout>