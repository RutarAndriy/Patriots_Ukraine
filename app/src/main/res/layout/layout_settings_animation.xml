            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_preview_05"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_28"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_preview_06"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_29"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_preview_07"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_30"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_preview_off"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_31"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

    </RadioGroup>

</RelativeLayout>