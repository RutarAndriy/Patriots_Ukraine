            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_close_05"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_20"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_close_06"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_21"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_close_07"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_22"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/anim_close_off"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_animation_23"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"/>

    </RadioGroup>

    <View
        android:id="@+id/animation_divider_03"
        android:layout_below="@id/rg_anim_close"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="?attr/color_background" />

    <RadioGroup
        android:id="@+id/rg_anim_preview"
        android:layout_below="@id/animation_divider_03"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatRadioButton
