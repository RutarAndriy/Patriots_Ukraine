                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/web_behavior_off"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Web behavior off"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_web_behavior_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/behavior_f"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="F"
                    android:textColor="?attr/color_text_dark"
                    android:textSize="@dimen/size_text_normal" />

                <CheckBox
                    android:id="@+id/behavior_t"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="T"
                    android:textColor="?attr/color_text_dark"
                    android:textSize="@dimen/size_text_normal" />

                <CheckBox
                    android:id="@+id/behavior_link"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="L"
                    android:textColor="?attr/color_text_dark"
                    android:textSize="@dimen/size_text_normal" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_font_size"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <SeekBar
                    android:id="@+id/font_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_anim_toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_anim_toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/anim_toolbar_01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="A1"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_toolbar_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A2"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_toolbar_03"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A3"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_toolbar_off"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A4"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_anim_show"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_anim_open"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/anim_open_01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="A1"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A2"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_03"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A3"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_04"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A4"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_05"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A5"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_06"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A6"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_07"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A7"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_open_off"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A8"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_anim_hide"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_anim_close"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/anim_close_01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="A1"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_close_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A2"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_close_03"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A3"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_close_04"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A4"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_close_05"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A5"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_close_06"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A6"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_close_07"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
