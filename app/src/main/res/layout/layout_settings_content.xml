                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Status bar off"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />
                </RadioGroup>

