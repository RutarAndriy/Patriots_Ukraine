                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/orientation_port"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_orientation_01"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/orientation_land"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_orientation_02"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/orientation_auto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="@string/settings_orientation_03"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />
                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_statusbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_statusbar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/statusbar_on"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Status bar on"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/statusbar_off"
