                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_anim_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/anim_preview_01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="A1"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A2"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_03"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A3"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_04"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A4"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_05"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A5"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_06"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A6"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_07"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A7"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/anim_preview_off"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="A8"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

