<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarThumbHorizontal="?attr/scrollbar"
        android:scrollbarThumbVertical="?attr/scrollbar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/settings_language"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_language"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/lang_uk"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_language_01"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/lang_ru"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_language_02"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/lang_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="@string/settings_language_03"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/settings_theme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/bg_theme"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <RadioButton
                        android:id="@+id/theme_01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_01"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_02"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_03"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_03"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_04"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="@string/settings_theme_04"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_05"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_05"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_06"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_06"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_07"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_07"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_08"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_08"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_09"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_09"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                    <RadioButton
                        android:id="@+id/theme_random"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_theme_10"
                        android:textColor="?attr/color_text_dark"
                        android:textSize="@dimen/size_text_normal" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
