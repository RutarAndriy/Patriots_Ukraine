            app:buttonTint="?attr/color_text_dark"
            tools:ignore="HardcodedText"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/font_14"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Segoe_Script"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"
            tools:ignore="HardcodedText"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/font_15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B52"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"
            tools:ignore="HardcodedText"/>

        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/font_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="iFlash_502"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            app:buttonTint="?attr/color_text_dark"
            tools:ignore="HardcodedText"/>

    </RadioGroup>

    <View
        android:id="@+id/font_divider_01"
        android:layout_below="@id/rg_font"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="?attr/color_background" />

    <RelativeLayout
        android:layout_below="@id/font_divider_01"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/font_size_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:textColor="?attr/color_text_dark"
            android:textSize="@dimen/size_text_normal"
            android:layout_marginTop="@dimen/value_small"
            android:text="@string/settings_font_02"/>

        <SeekBar
            android:max="8"
            android:progress="3"
            android:id="@+id/font_size_seekbar"
            android:layout_below="@id/font_size_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/value_normal"
            android:layout_marginBottom="@dimen/value_normal"
            style="@style/Widget.AppCompat.SeekBar.Discrete"/>

    </RelativeLayout>

</RelativeLayout>