<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <android.support.v7.widget.AppCompatCheckBox
        android:id="@+id/share_f"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_share_02"
        android:textColor="?attr/color_text_dark"
        android:textSize="@dimen/size_text_normal"
        app:buttonTint="?attr/color_text_dark"/>

    <android.support.v7.widget.AppCompatCheckBox
        android:id="@+id/share_t"
        android:layout_below="@id/share_f"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_share_03"
        android:textColor="?attr/color_text_dark"
        android:textSize="@dimen/size_text_normal"
        app:buttonTint="?attr/color_text_dark"/>

    <android.support.v7.widget.AppCompatCheckBox
        android:id="@+id/share_link"
        android:layout_below="@id/share_t"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_share_04"
        android:textColor="?attr/color_text_dark"
        android:textSize="@dimen/size_text_normal"
        app:buttonTint="?attr/color_text_dark"/>

</RelativeLayout>