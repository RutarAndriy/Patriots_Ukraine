<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/share_image"
        android:layout_width="@dimen/size_tool_bar"
        android:layout_height="@dimen/size_tool_bar"
        android:padding="@dimen/value_normal"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/im_preview_not_exist" />

    <TextView
        android:id="@+id/share_text"
        android:layout_width="match_parent"
        android:layout_height="@dimen/size_tool_bar"
        android:layout_marginLeft="@dimen/value_normal"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:text="@android:string/unknownName"
        android:textColor="?attr/color_text_dark"
        android:textSize="@dimen/size_text_large" />

</LinearLayout>