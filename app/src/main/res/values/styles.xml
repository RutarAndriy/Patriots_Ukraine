<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ////////////////////////////////////////////////////////////////////////////////////// -->

    <style name="Theme_Yellow" parent="Theme.AppCompat.Light.NoActionBar">

        <item name="colorAccent">#f1f100</item>
        <item name="colorPrimary">#f1f100</item>
        <item name="colorPrimaryDark">#dcdc00</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="color_list_item_light">#616161</item>
        <item name="color_list_item_dark">#4F4F4F</item>
        <item name="color_background">#4d4d4d</item>
        <item name="color_text_light">#464646</item>
        <item name="color_text_dark">#f1f1f1</item>
        <item name="color_link">#f1f100</item>

        <item name="colorControlNormal">#f1f1f1</item>
        <item name="colorControlActivated">#f1f100</item>
        <item name="colorControlHighlight">#f1f100</item>

    </style>

    <!-- /// Світла тема вибору дати ////////////////////////////////////////////////////////// -->

    <style name="Date_Picker_Light" parent="TextAppearance.MaterialCalendarWidget.Date">
        <item name="android:textColor">@color/date_picker_light</item>
    </style>

    <!-- /// Темна тема вибору дати /////////////////////////////////////////////////////////// -->

    <style name="Date_Picker_Dark" parent="TextAppearance.MaterialCalendarWidget.Date">
        <item name="android:textColor">@color/date_picker_dark</item>
    </style>

    <!-- /// Тема заголовка діалогу вибору дати /////////////////////////////////////////////// -->

    <style name="Date_Picker_Header" parent="TextAppearance.MaterialCalendarWidget.Date">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- /// Тема, яка відображається при запуску програми //////////////////////////////////// -->

    <style name="Launch_Theme" parent="Theme.AppCompat.Light.NoActionBar" >
        <item name="android:windowBackground">@xml/splash_screen</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorPrimaryDark">#0073FF</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

    </style>

    <!-- Діалогове вікно браузера -->

    <style name="Dialog_Web_View" parent="android:Theme.Dialog">

        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">fill_parent</item>

        <item name="android:layout_marginTop">@dimen/share_web_view_padding</item>
        <item name="android:layout_marginBottom">@dimen/share_web_view_padding</item>

        <item name="android:windowBackground">@null</item>
        <item name="android:windowNoTitle">true</item>
        <!--<item name="android:windowIsFloating">false</item>-->

    </style>

    <!-- /// Колір активної підказки для EditText ///////////////////////////////////////////// -->

    <style name="Text_Input_Layout_Active_Style" parent="@android:style/TextAppearance">
        <item name="android:textColor">?attr/color_theme_text</item>
    </style>

</resources>