<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme_Basic_Light" parent="Theme.AppCompat.Light.NoActionBar">

        <item name="colorAccent">@color/basic_light_primary_light</item>
        <item name="colorPrimary">@color/basic_light_primary_light</item>
        <item name="colorPrimaryDark">@color/basic_light_primary_dark</item>
        <item name="colorControlNormal">@color/basic_color_dark</item>
        <item name="colorControlActivated">@color/basic_light_primary_light</item>
        <item name="colorControlHighlight">@color/basic_light_primary_light</item>

        <item name="color_link">@color/basic_light_primary_dark</item>
        <item name="color_background">@color/basic_color_light</item>
        <item name="color_trident_in">@color/basic_color_light</item>
        <item name="color_trident_out">@color/basic_light_primary_light</item>

        <item name="color_outline">@color/basic_color_black</item>
        <item name="color_theme_text">@color/basic_light_primary_light</item>

        <item name="color_behavior_in">@color/basic_light_primary_light</item>
        <item name="color_behavior_out">@color/basic_color_light</item>
        <item name="color_behavior_text">@color/basic_color_light</item>

        <item name="color_list_item_light">@color/basic_color_light</item>
        <item name="color_list_item_dark">@color/basic_light_additional</item>

        <item name="color_text_light">@color/basic_color_light</item>
        <item name="color_text_dark">@color/basic_color_dark</item>

        <item name="android:typeface">serif</item>

    </style>

    <!-- ////////////////////////////////////////////////////////////////////////////////////// -->

    <style name="Theme_Basic_Dark" parent="Theme.AppCompat.Light.NoActionBar">

        <item name="colorAccent">@color/basic_dark_primary_light</item>
        <item name="colorPrimary">@color/basic_dark_primary_light</item>
        <item name="colorPrimaryDark">@color/basic_dark_primary_dark</item>
        <item name="colorControlNormal">@color/basic_color_dark</item>
        <item name="colorControlActivated">@color/basic_dark_primary_light</item>
        <item name="colorControlHighlight">@color/basic_dark_primary_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="color_link">@color/basic_dark_primary_light</item>
        <item name="color_background">@color/basic_color_black</item>
        <item name="color_trident_in">@color/basic_color_black</item>
        <item name="color_trident_out">@color/basic_dark_primary_light</item>

        <item name="color_outline">@color/basic_dark_primary_dark</item>
        <item name="color_theme_text">@color/basic_dark_primary_light</item>

        <item name="color_behavior_in">@color/basic_dark_primary_light</item>
        <item name="color_behavior_out">@color/basic_color_black</item>
        <item name="color_behavior_text">@color/basic_color_black</item>

        <item name="color_list_item_light">@color/basic_color_black</item>
        <item name="color_list_item_dark">@color/basic_color_dark</item>

        <item name="color_text_light">@color/basic_color_black</item>
        <item name="color_text_dark">@color/basic_color_light</item>

        <item name="android:typeface">serif</item>

    </style>

</resources>