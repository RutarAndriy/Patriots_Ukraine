<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme_Default_Light" parent="Theme_Basic_Light">

        <item name="colorAccent">@color/default_light_primary_light</item>
        <item name="colorPrimary">@color/default_light_primary_light</item>
        <item name="colorPrimaryDark">@color/default_light_primary_dark</item>
        <item name="colorControlNormal">@color/basic_color_dark</item>
        <item name="colorControlActivated">@color/default_light_primary_light</item>
        <item name="colorControlHighlight">@color/default_light_primary_light</item>

        <item name="color_link">@color/default_light_primary_dark</item>
        <item name="color_background">@color/basic_color_light</item>
        <item name="color_trident_in">@color/default_light_trident_in</item>
        <item name="color_trident_out">@color/default_light_trident_out</item>

        <item name="color_outline">@color/basic_color_black</item>
        <item name="color_theme_text">@color/default_light_primary_light</item>

        <item name="color_behavior_in">@color/default_light_primary_light</item>
        <item name="color_behavior_out">@color/basic_color_light</item>
        <item name="color_behavior_text">@color/basic_color_light</item>

        <item name="color_list_item_light">@color/basic_color_light</item>
        <item name="color_list_item_dark">@color/default_light_additional</item>

        <item name="color_text_light">@color/basic_color_light</item>
        <item name="color_text_dark">@color/basic_color_dark</item>

        <item name="scrollbar">@xml/scrollbar_blue</item>
        <item name="search_run">@xml/search_run_blue_light</item>
        <item name="share_loading">@xml/share_loading_blue_light</item>

    </style>

    <!-- ////////////////////////////////////////////////////////////////////////////////////// -->

    <style name="Theme_Default_Dark" parent="Theme_Basic_Dark">

        <item name="colorAccent">@color/default_dark_primary_light</item>
        <item name="colorPrimary">@color/default_dark_primary_light</item>
        <item name="colorPrimaryDark">@color/default_dark_primary_dark</item>
        <item name="colorControlNormal">@color/basic_color_dark</item>
        <item name="colorControlActivated">@color/default_dark_primary_light</item>
        <item name="colorControlHighlight">@color/default_dark_primary_light</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="color_link">@color/default_dark_primary_light</item>
        <item name="color_background">@color/basic_color_dark</item>
        <item name="color_trident_in">@color/default_dark_trident_in</item>
        <item name="color_trident_out">@color/default_dark_trident_out</item>

        <item name="color_outline">@color/default_dark_primary_dark</item>
        <item name="color_theme_text">@color/default_dark_primary_light</item>

        <item name="color_behavior_in">@color/default_dark_primary_light</item>
        <item name="color_behavior_out">@color/basic_color_light</item>
        <item name="color_behavior_text">@color/basic_color_light</item>

        <item name="color_list_item_light">@color/basic_color_black</item>
        <item name="color_list_item_dark">@color/basic_color_dark</item>

        <item name="color_text_light">@color/basic_color_light</item>
        <item name="color_text_dark">@color/basic_color_light</item>

        <item name="scrollbar">@xml/scrollbar_blue</item>
        <item name="search_run">@xml/search_run_blue_dark</item>
        <item name="share_loading">@xml/share_loading_blue_dark</item>

    </style>

</resources>