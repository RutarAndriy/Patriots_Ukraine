<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme_Lime_Light" parent="Theme_Basic_Light">

        <item name="colorAccent">#aeea00</item>
        <item name="colorPrimary">#aeea00</item>
        <item name="colorPrimaryDark">#88b700</item>
        <item name="colorControlNormal">#404040</item>
        <item name="colorControlActivated">#404040</item>
        <item name="colorControlHighlight">#404040</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="color_link">#404040</item>
        <item name="color_background">#F7F7F7</item>
        <item name="color_trident_in">#404040</item>
        <item name="color_trident_out">#aeea00</item>

        <item name="color_outline">#646464</item>
        <item name="color_theme_text">#404040</item>

        <item name="color_behavior_in">#aeea00</item>
        <item name="color_behavior_out">#404040</item>
        <item name="color_behavior_text">#404040</item>

        <item name="color_list_item_light">#F7F7F7</item>
        <item name="color_list_item_dark">#F1FAD7</item>

        <item name="color_text_light">#404040</item>
        <item name="color_text_dark">#404040</item>

        <item name="scrollbar">@xml/scrollbar_lime</item>
        <item name="search_run">@xml/search_run_lime_light</item>
        <item name="share_loading">@xml/share_loading_lime_light</item>

    </style>

    <!-- ////////////////////////////////////////////////////////////////////////////////////// -->

    <style name="Theme_Lime_Dark" parent="Theme_Basic_Dark">

        <item name="colorAccent">#aeea00</item>
        <item name="colorPrimary">#aeea00</item>
        <item name="colorPrimaryDark">#88b700</item>
        <item name="colorControlNormal">#404040</item>
        <item name="colorControlActivated">#aeea00</item>
        <item name="colorControlHighlight">#aeea00</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="color_link">#aeea00</item>
        <item name="color_background">#282828</item>
        <item name="color_trident_in">#282828</item>
        <item name="color_trident_out">#aeea00</item>

        <item name="color_outline">#88b700</item>
        <item name="color_theme_text">#aeea00</item>

        <item name="color_behavior_in">#aeea00</item>
        <item name="color_behavior_out">#282828</item>
        <item name="color_behavior_text">#282828</item>

        <item name="color_list_item_light">#282828</item>
        <item name="color_list_item_dark">#404040</item>

        <item name="color_text_light">#282828</item>
        <item name="color_text_dark">#F7F7F7</item>

        <item name="scrollbar">@xml/scrollbar_lime</item>
        <item name="search_run">@xml/search_run_lime_dark</item>
        <item name="share_loading">@xml/share_loading_lime_dark</item>

    </style>

</resources>