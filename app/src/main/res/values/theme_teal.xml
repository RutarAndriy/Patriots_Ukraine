<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme_Teal_Light" parent="Theme_Basic_Light">

        <item name="colorAccent">#00bfa5</item>
        <item name="colorPrimary">#00bfa5</item>
        <item name="colorPrimaryDark">#008c79</item>
        <item name="colorControlNormal">#404040</item>
