<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme_Yellow_Light" parent="Theme_Basic_Light">

        <item name="colorAccent">#fff176</item>
        <item name="colorPrimary">#fff176</item>
        <item name="colorPrimaryDark">#F0DD42</item>
        <item name="colorControlNormal">#404040</item>
        <item name="colorControlActivated">#404040</item>
        <item name="colorControlHighlight">#404040</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="color_link">#404040</item>
        <item name="color_background">#F7F7F7</item>
        <item name="color_trident_in">#404040</item>
        <item name="color_trident_out">#fff176</item>

        <item name="color_outline">#646464</item>
        <item name="color_theme_text">#404040</item>

        <item name="color_behavior_in">#fff176</item>
        <item name="color_behavior_out">#404040</item>
        <item name="color_behavior_text">#404040</item>

        <item name="color_list_item_light">#F7F7F7</item>
        <item name="color_list_item_dark">#FEFBE9</item>

        <item name="color_text_light">#404040</item>
        <item name="color_text_dark">#404040</item>

        <item name="scrollbar">@xml/scrollbar_yellow</item>
        <item name="search_run">@xml/search_run_yellow_light</item>
        <item name="share_loading">@xml/share_loading_yellow_light</item>

    </style>

    <!-- ////////////////////////////////////////////////////////////////////////////////////// -->

